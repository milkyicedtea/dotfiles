alias pacman='sudo pacman'

alias zed='zeditor'

export STEAM_COMPAT_CLIENT_INSTALL_PATH="$HOME/.local/share/Steam"
export STEAM_COMPAT_DATA_PATH="$HOME/.local/share/Steam/steamapps/compatdata/0"
alias protonge='"$HOME/.local/share/Steam/compatibilitytools.d/Proton-GE Latest/proton"'

alias config="git --git-dir=$HOME/.cfg/ --work-tree=$HOME"
